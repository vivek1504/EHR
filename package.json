{
  "name": "ehr-backend",
  "version": "1.0.0",
  "description": "EHR Annotation Platform Backend — Cloud-native clinical NLP tool",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "seed": "tsx src/scripts/seed.ts",
    "cleanup": "tsx src/scripts/cleanup.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "hono": "^4.6.12",
    "pg": "^8.22.0",
    "zod": "^3.25.76"
  }
}
